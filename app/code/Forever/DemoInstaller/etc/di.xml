<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Importer pool: step "type" => importer instance -->
    <type name="Forever\DemoInstaller\Model\ImporterPool">
        <arguments>
            <argument name="importers" xsi:type="array">
                <item name="media"     xsi:type="object">Forever\DemoInstaller\Model\Importer\MediaImporter</item>
                <item name="cms_block" xsi:type="object">Forever\DemoInstaller\Model\Importer\CmsBlockImporter</item>
                <item name="cms_page"  xsi:type="object">Forever\DemoInstaller\Model\Importer\CmsPageImporter</item>
                <item name="widget"    xsi:type="object">Forever\DemoInstaller\Model\Importer\WidgetImporter</item>
                <item name="table"     xsi:type="object">Forever\DemoInstaller\Model\Importer\GenericTableImporter</item>
                <item name="config"    xsi:type="object">Forever\DemoInstaller\Model\Importer\ConfigImporter</item>
                <item name="deployment_config" xsi:type="object">Forever\DemoInstaller\Model\Importer\DeploymentConfigImporter</item>
                <item name="theme"     xsi:type="object">Forever\DemoInstaller\Model\Importer\ThemeImporter</item>
            </argument>
        </arguments>
    </type>

    <!-- Exporter pool -->
    <type name="Forever\DemoInstaller\Model\ExporterPool">
        <arguments>
            <argument name="exporters" xsi:type="array">
                <item name="table"     xsi:type="object">Forever\DemoInstaller\Model\Exporter\GenericTableExporter</item>
                <item name="config"    xsi:type="object">Forever\DemoInstaller\Model\Exporter\ConfigExporter</item>
                <item name="widget"    xsi:type="object">Forever\DemoInstaller\Model\Exporter\WidgetExporter</item>
                <item name="cms_block" xsi:type="object">Forever\DemoInstaller\Model\Exporter\CmsBlockExporter</item>
                <item name="cms_page"  xsi:type="object">Forever\DemoInstaller\Model\Exporter\CmsPageExporter</item>
            </argument>
        </arguments>
    </type>

    <!-- Register CLI commands -->
    <type name="Magento\Framework\Console\CommandListInterface">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="forever_demo_list"   xsi:type="object">Forever\DemoInstaller\Console\Command\DemoListCommand</item>
                <item name="forever_demo_import" xsi:type="object">Forever\DemoInstaller\Console\Command\DemoImportCommand</item>
                <item name="forever_demo_export" xsi:type="object">Forever\DemoInstaller\Console\Command\DemoExportCommand</item>
            </argument>
        </arguments>
    </type>
</config>
