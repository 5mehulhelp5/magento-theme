<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../../../lib/internal/Magento/Framework/View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="Forever_Megamenu::css/menu-desktop-fix.css"/>
    </head>
    <body>
        <referenceBlock name="store.menu">
            <block class="Forever\Megamenu\Block\Menu" name="catalog.topnav" template="Forever_Megamenu::topmenu.phtml" before="-">
                <block class="Magento\Theme\Block\Html\Topmenu" name="catalog.topnav.default" template="Magento_Theme::html/topmenu.phtml"/>
            </block>
            <block class="Forever\Megamenu\Block\Menu" name="catalog.mobile.topnav" template="Forever_Megamenu::topmenu.phtml" after="catalog.topnav">
                <block class="Magento\Theme\Block\Html\Topmenu" name="catalog.mobile.topnav.default" template="Magento_Theme::html/topmenu.phtml"/>
            </block>
        </referenceBlock>
    </body>
</page>
