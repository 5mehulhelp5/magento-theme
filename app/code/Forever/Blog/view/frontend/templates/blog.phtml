                                    width="1170"
                                    height="940" 
                                />
                            <?php else: ?>
                                <img class="attachment-drile_blog_thumb size-drile_blog_thumb wp-post-image"
                                    src="<?= /* @noEscape */ $block->getPlaceHolderImage(); ?>"
                                    alt="<?= /* @noEscape */ $row->getBlogImage() ?>"
                                    width="1170"
                                    height="940" 
                                />
                            <?php endif; ?>
