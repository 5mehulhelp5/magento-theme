<h3 class="blog-heading"><?= __("Blog") ?></h3>
    <div class="blog-holder">
       <div class="blog-items owl-carousel owl-theme">    
            <?php if (count($colletion)): ?>
                <?php foreach ($colletion as $row): ?>
                    <div class="item">
                        <div class="article-thumbnail owl-carousel owl-theme">
                            <div class="img-inner">
                            <?php if($row->getBlogImage()): ?>
                                <img class="attachment-drile_blog_thumb size-drile_blog_thumb wp-post-image"
                                    src="<?= /* @noEscape */ $block->getBlogImage($row->getBlogImage()) ?>"
