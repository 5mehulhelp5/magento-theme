<?xml version="1.0"?>
<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp:etc/csp_whitelist.xsd">
    <policies>
        <policy id="script-src">
            <values>
                <value id="google-maps-api" type="host">https://maps.googleapis.com</value>
                <value id="google-static" type="host">https://maps.gstatic.com</value>
            </values>
        </policy>
        <policy id="img-src">
            <values>
                <value id="google-maps-images" type="host">https://maps.googleapis.com</value>
                <value id="google-maps-static-images" type="host">https://maps.gstatic.com</value>
                <value id="google-maps" type="host">https://maps.google.com</value>
                <value id="google-data" type="host">data:</value>
            </values>
        </policy>
        <policy id="style-src">
            <values>
                <value id="google-maps-styles" type="host">https://fonts.googleapis.com</value>
            </values>
        </policy>
        <policy id="font-src">
            <values>
                <value id="google-fonts" type="host">https://fonts.gstatic.com</value>
            </values>
        </policy>
    </policies>
</csp_whitelist>
